{
  "output_dir": "~/Videos/MeetingRecorder",
  "record_screen": true,
  "capture_mode": "fullscreen",
  "capture_region": "",
  "record_mic": true,
  "record_system_audio": true,
  "mic_volume": 0.6,
  "system_volume": 0.6,
  "normalize_voice": true,
  "noise_cancellation": true,
  "noise_model_path": "",
  "auto_record": false,
  "framerate": 30,
  "video_codec": "libx264",
  "video_preset": "veryfast",
  "container": "mkv",
  "prompt_timeout_seconds": 30,
  "start_debounce_seconds": 3.0,
  "stop_debounce_seconds": 5.0,
  "poll_interval_seconds": 1.0,
  "min_recording_seconds": 3.0,
  "allowlist": [
    {"match": "zoom", "app": "Zoom"},
    {"match": "teams", "app": "Teams"},
    {"match": "teams-for-linux", "app": "Teams"},
    {"match": "discord", "app": "Discord"},
    {"match": "slack", "app": "Slack"},
    {"match": "webex", "app": "Webex"},
    {"match": "firefox", "app": "Firefox"},
    {"match": "chrome", "app": "Chrome"},
    {"match": "chromium", "app": "Chromium"},
    {"match": "brave", "app": "Brave"},
    {"match": "vivaldi", "app": "Vivaldi"}
  ]
}
