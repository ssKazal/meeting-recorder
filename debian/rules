#!/usr/bin/make -f
# Pure-Python application: nothing to compile, so the default dh sequence just
# needs an install override. Keep this in step with packaging/build-deb.sh.

export DH_VERBOSE = 1
PKGDIR = debian/meeting-recorder
SITE   = $(PKGDIR)/usr/lib/python3/dist-packages/meeting_recorder

%:
	dh $@

override_dh_auto_build:

override_dh_auto_test:
	python3 tests/run_tests.py

override_dh_auto_install:
	install -d $(SITE)
	install -m 644 meeting_recorder/*.py $(SITE)/
	install -m 644 meeting_recorder/default_config.json $(SITE)/
	install -D -m 755 packaging/meeting-recorder.bin $(PKGDIR)/usr/bin/meeting-recorder
	install -D -m 644 packaging/meeting-recorder.service \
	    $(PKGDIR)/usr/lib/systemd/user/meeting-recorder.service
	install -D -m 644 packaging/meeting-recorder-settings.desktop \
	    $(PKGDIR)/usr/share/applications/meeting-recorder-settings.desktop
	install -D -m 644 packaging/meeting-recorder.svg \
	    $(PKGDIR)/usr/share/icons/hicolor/scalable/apps/meeting-recorder.svg

override_dh_installman:
	dh_installman packaging/meeting-recorder.1
